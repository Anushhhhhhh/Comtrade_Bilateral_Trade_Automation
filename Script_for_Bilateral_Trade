# Step 2. Cleaning Data
def file_cleaner(file_name):
    with open(file_name) as f:
        file_reader = json.load(f)
        country_a = pd.DataFrame(file_reader)
        return country_a
# file_cleaner(r"Country_A-only_partners.json")

merge_df = pd.DataFrame()
for files_names in os.listdir(report_directory):
    print(f"File Names: {files_names}\n")
    if files_names.endswith(".json"):
        dfs = file_cleaner(files_names)
        dfs["source_file"] = files_names
        merge_df = pd.concat([dfs,merge_df])
